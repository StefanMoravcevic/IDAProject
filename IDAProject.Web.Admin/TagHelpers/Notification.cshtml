@model IDAProject.Web.Admin.Models.TagHelpers.NotificationViewModel
@using IDAProject.Web.Admin.Models.TagHelpers


@if (Model.Type == NotificationType.Success)
{
    <div class="alert alert-success" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <strong>Information</strong> @Model.Message
    </div>
}
else if (Model.Type == NotificationType.Info)
{
    <div class="alert alert-info" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <strong>Information</strong> @Model.Message
    </div>
}
else if (Model.Type == NotificationType.Warning)
{
    <div class="alert alert-warning" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <strong>Validation</strong> @Model.Message
    </div>
}
else if (Model.Type == NotificationType.Error)
{
    <div class="alert alert-danger" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <strong>Error</strong> @Model.Message
    </div>
}