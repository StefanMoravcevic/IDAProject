{
    "version": "1.0",
    "defaultProvider": "jsdelivr",
    "libraries": [
        {
            "library": "print-js@1.6.0",
            "destination": "wwwroot/lib/print-js/",
            "files": [
                "dist/print.css",
                "dist/print.js",
                "dist/print.map",
                "dist/print.min.css",
                "dist/print.min.js"
            ]
        },
        {
            "library": "@microsoft/signalr@latest",
            "destination": "wwwroot/js/signalr/",
            "files": [
                "dist/browser/signalr.js",
                "dist/browser/signalr.min.js"
            ]
        }
    ]
}