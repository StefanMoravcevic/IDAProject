@model IDAProject.Web.Admin.Models.ViewModels.Roles.RoleViewModel;
@using IDAProject.Web.Helpers;
@using IDAProject.Web.Models.General;
@using IDAProject.Web.Admin.Models.Common;
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> localizer
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@{
    var urlRoleFeatureCreate = Url.RouteUrl(RouteNames.RoleFeature_Create);
    var urlRoleFeatureDelete = Url.RouteUrl(RouteNames.RoleFeature_Delete, new { roleFeatureId = "111" });
    var getUrl = Url.RouteUrl(RouteNames.RoleFeatures_Get, new { roleId = Model.Role.Id });
}
<div class="row" id="editForm">
    <input type="hidden" value="@Model.Role.Id" name="Id" id="Id" />
    <div class="col-md-12">
        <label for="Role" class="">@localizer["Role name"]</label>
        <input type="text" id="Role" name="Role" value="@Model.Role.Name" inputType="input" readonly="readonly" class="form-control text-dark" />
        <div style="margin-top:20px !important; margin-bottom:0px;">
            <label>@localizer["Features"]</label>
            <tms-select name="Features" options="@Model.Features" id="Features" empty-option-text="@localizer["Select feature"]..." />
        </div>
        <div class="btn-list">
            <button class="btn btn-primary" id="addButton">@localizer["Assign"]</button>
        </div>
        <div class="form-group">
            <label style="margin-top:20px; margin-bottom:20px;">@localizer["Assigned features"]:</label>
            <div class="panel panel-primary" id="roleFeaturesTableWrapper">
                <partial name="RoleFeaturesRecords" model="@Model.RoleFeatures" />
            </div>
@*            <div class="card-body">
                <tms-ajax-table id="tableRoleFeatures" view-model="Model.RoleFeatures" table-settings-reference-table="AspNetRoleFeatures" />
            </div>
*@        </div>
    </div>
</div>
@section Styles {
    <link rel="stylesheet" type="text/css" href="~/lib/select2/select2.min.css" />
}
    @section Scripts {

    <script type="text/javascript" src="~/lib/select2/select2.min.js"></script>
    <script type="text/javascript" src="../js/jquery-3.1.1.min.js"></script>
    <script type="text/javascript" src="../js/jquery-ui.js"></script>
    @* <link rel="stylesheet" href="https://cdn.datatables.net/buttons/1.4.2/css/buttons.dataTables.min.css" type="text/css" media="all"> *@
    <link rel="stylesheet" href="~/lib/datatables.net-buttons/css/buttons.datatables.min.css" rel="stylesheet" type="text/css" media="all" />
    <script type="text/javascript" charset="utf8" src="//cdn.datatables.net/1.10.16/js/jquery.dataTables.js"></script>
    @* <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/buttons/1.4.2/js/dataTables.buttons.min.js"></script> *@
    <script type="text/javascript" charset="utf8" src="~/lib/datatables.net-buttons/js/datatables.buttons.min.js"></script>
    <script type="text/javascript" charset="utf8" src="//cdn.datatables.net/buttons/1.4.2/js/buttons.flash.min.js"></script>
    <script type="text/javascript" charset="utf8" src="//cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.32/vfs_fonts.js"></script>
    <script type="text/javascript" charset="utf8" src="//cdn.datatables.net/buttons/1.4.2/js/buttons.html5.min.js"></script>
    }
    <script type="text/javascript">
        var tableParams = {
            "searching": false,
            "fixedColumns": true,
            "autoWidth": false
        };

        function reloadRoleFeatureTable() {
            $('#tableRoleFeatures').DataTable({
                searching: false,
                fixedColumns: true,
                autoWidth: false,
                dom: 'Blfrtip',
                buttons: [
                    'colvis',
                    'excel',
                    'print'
                ]
            });
        }

        function ajaxReloadRoleFeatureTable() {
            $.ajax({
                url: "@getUrl",
                method: "GET",
                success: function (htmlResponse) {
                    $('#tableRoleFeatures').DataTable().clear().destroy();

                    $('#roleFeaturesTableWrapper').html(htmlResponse);
                    setTimeout(reloadRoleFeatureTable, 100);
                }
            });
        }

        $(document).ready(function () {

            reloadRoleFeatureTable();

            $("#tableRoleFeatures").on("click", "button[name='delete']", function () {
                var id = $(this).val();
                $.ajax({
                    url: "@urlRoleFeatureDelete".replace("111", id),
                    method: "DELETE",
                    success: function (response) {
                        Swal.fire({
                            icon: 'success',
                            title: 'The feature has been removed successfuly.',
                        });
                        ajaxReloadRoleFeatureTable();
                    }
                });
            });

            $("#addButton").click(function () {
                var roleId = $("#Id").val();
                var featureId = $("#Features").val();
                //var featureName = $("#Features option:selected").text();

                if (featureId > 0) {
                    $.ajax({
                        url: '@urlRoleFeatureCreate',
                        method: 'POST',
                        data: {
                            FeatureId: featureId,
                            RoleId: roleId
                        },
                        success: function (response) {
                            if (response.valid) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'The feature has been assigned successfuly.',
                                });
                                ajaxReloadRoleFeatureTable();
                            }
                            else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: response.message
                                });
                            }
                        },
                    });
                }
                else {
                    Swal.fire({
                        icon: 'info',
                        text: "You must select feature from the dropdown list."
                    });
                }
            });
        });
    </script>

