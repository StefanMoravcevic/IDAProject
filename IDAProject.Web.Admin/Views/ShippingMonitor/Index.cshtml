@model IDAProject.Web.Admin.Models.ViewModels.PackagingMonitor.PackagingMonitorViewModel
@using Microsoft.Extensions.Localization
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@inject IStringLocalizer<SharedResources> localizer

@{
    ViewData["Title"] = "Shipping monitor";
    Layout = "~/Views/Shared/_LayoutNoSidebar.cshtml";
}
<link rel="stylesheet" type="text/css" href="~/lib/select2/select2.min.css" />
<script type="text/javascript" src="~/lib/select2/select2.min.js"></script>
@* <script type="text/javascript" src="~/js/packagingOrder.js"></script> *@

<style type="text/css">
    body {
        background: url('/images/wintlogo.png') no-repeat center center fixed;
        height: 100%;
        margin: 0;
        box-sizing: border-box; /* Include padding in the element's total width and height */
        background-size: 50%;
    }

    .table-container {
        height: 100%;
        padding: 10px; /* Adjust the padding as needed */
        box-sizing: border-box;
        background-color: rgba(255, 255, 255, 0.9); /* Solid background with slight transparency */
    }

    .tablePackage {
        width: 100%;
        margin: 0;
        table-layout: fixed;
        border-collapse: collapse; /* Make table borders look cleaner */
    }

    .table1 {
        height: 70vh;
        overflow-y: auto; /* Allow scrolling if content overflows */
    }

    .table2 {
        height: 30vh;
        overflow-y: auto; /* Allow scrolling if content overflows */
    }

    thead td {
        background-color: #00adef; /* Bright blue from the logo */
        color: white;
        padding: 9px; /* Add padding for better readability */
        font-size: 1.2em; /* Slightly larger font for headers */
        font-weight: bold; /* Bold font for headers */
        position: sticky;
        top: 0;
    }

    tbody td {
        border: 1px solid #ddd;
        text-align: left;
        padding: 6px; /* Add padding for better readability */
        background-color: #ffffff; /* White background for rows */
    }

    tbody tr:nth-child(even) {
        background-color: #f9f9f9; /* Light grey for alternating rows */
    }

    .table-container h1 {
        color: #00adef; /* Bright blue from the logo */
        text-align: center; /* Center the header text */
        font-size: 2em; /* Increase the font size of the header */
    }

    tfoot td {
        background-color: #333; /* Dark footer for contrast */
        color: white;
        padding: 10px;
    }
    @@keyframes blink {
        50% { opacity: 0.2; }
    }

    .past-date td {
        animation: blink 2s infinite;
        color: red;
        background-color: transparent !important;
    }
    td.status-zaOdvajanje {
        color: #BF3131 !important;
        font-weight: bold;
    }
    td.status-odvajanje {
        color: #FFB433 !important;
        font-weight: bold;
    }
    td.status-odvojen {
        color: #1F7D53 !important;
        font-weight: bold;
    }
    td.status-zapakovan {
        font-weight: bold;
    }
</style>

<tms-input type="Hidden" name="ApiUrl" id="ApiUrl" value="@Model.ApiUrl" />

