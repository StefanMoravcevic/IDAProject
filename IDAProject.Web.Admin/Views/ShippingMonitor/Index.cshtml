<script type="text/javascript">

    let apiUrl = $("#ApiUrl").val();
    const connection = new signalR.HubConnectionBuilder()
        .withUrl(apiUrl + "/packageStatusHub", {
            skipNegotiation: true,
            transport: signalR.HttpTransportType.WebSockets
        })
        .build();

    connection.start().catch(err => console.error(err.toString()));

    connection.on("ReceiveShippingUpdate", (newShippingStatuses) => {
        let shippingList = newShippingStatuses.shippingList.filter(x => x.status != 'Zapakovan');
        let shippingListRight = newShippingStatuses.shippingList.filter(x => x.status == 'Zapakovan');
        let personalTakeofList = newShippingStatuses.personalTakeofList.filter(x => x.status != 'Zapakovan');
        let personalTakeofListRight = newShippingStatuses.personalTakeofList.filter(x => x.status == 'Zapakovan');

        let tableContainer = document.getElementById('topTable');
        tableContainer.innerHTML = createTopTable(shippingList);
        tableContainer = document.getElementById('topTableRight');
        tableContainer.innerHTML = createTopTableRight(shippingListRight);
        tableContainer = document.getElementById('bottomTable');
        tableContainer.innerHTML = createBottomTable(personalTakeofList);
        tableContainer = document.getElementById('bottomTableRight');
        tableContainer.innerHTML = createBottomTableRight(personalTakeofListRight);

    });

    function createTopTable(groupedData) {
        const container = document.createElement('div');

        const table = document.createElement('table');
        table.classList.add('tablePackage');

        const header = table.createTHead();
        const headerRow = header.insertRow(0);
        let cell0 = headerRow.insertCell(0);
        cell0.innerHTML = 'Opis rute razvoza';
        cell0.style.width = '18%';
        let cell1 = headerRow.insertCell(1);
        cell1.innerHTML = 'Vreme preseka';
        cell1.style.width = '16%';
        let cell2 = headerRow.insertCell(2);
        cell2.innerHTML = 'Vreme rute';
        cell2.style.width = '16%';
        let cell3 = headerRow.insertCell(3);
        cell3.innerHTML = 'Nalog za odvajanje';
        cell3.style.width = '36%';
        let cell4 = headerRow.insertCell(4);
        cell4.innerHTML = 'Status';
        cell4.style.width = '14%';
        const body = table.createTBody();
        groupedData.forEach(line => {
            let srcTranspRouteDescription = line.srcTranspRouteDescription !== null ? `${line.srcTranspRouteDescription}` : '';
            let srcTranspStartDateTime = line.srcTranspStartDateTime !== null ? formatTime(line.srcTranspStartDateTime) : '';
            let srcTranspCutOffDateTime = line.srcTranspCutOffDateTime !== null ? formatTime(line.srcTranspCutOffDateTime) : '';
            const cutoffDateTime = new Date(line.srcTranspCutOffDateTime);
            const now = new Date();
            let no = line.no !== null ? `${line.no}` : '';
            let status = line.status !== null ? `${line.status}` : '';
            let itemNo = line.itemNo !== null ? `${line.itemNo}` : '';
            const row = body.insertRow();
            if (cutoffDateTime < now){
                row.classList.add('past-date');
            }
            row.insertCell(0).innerHTML = srcTranspRouteDescription;
            row.insertCell(1).innerHTML = `${srcTranspCutOffDateTime}`;
            row.insertCell(2).innerHTML = `${srcTranspStartDateTime}`;
            row.insertCell(3).innerHTML = no;

            const statusCell = row.insertCell(4);
            statusCell.innerHTML = status;

            if (status === 'Za odvajanje') {
                statusCell.classList.add('status-zaOdvajanje');
            } else if (status === 'Odvajanje') {
                statusCell.classList.add('status-odvajanje');
            } else if (status === 'Odvojen') {
                statusCell.classList.add('status-odvojen');
            }
        });

        container.appendChild(table);
        return container.innerHTML;

    }
    function createTopTableRight(groupedData) {
        const container = document.createElement('div');

        const table = document.createElement('table');
        table.classList.add('tablePackage');

        const header = table.createTHead();
        const headerRow = header.insertRow(0);
        let cell0 = headerRow.insertCell(0);
        cell0.innerHTML = 'Opis rute razvoza';
        cell0.style.width = '12%';
        let cell1 = headerRow.insertCell(1);
        cell1.innerHTML = 'Vreme preseka';
        cell1.style.width = '9%';
        let cell2 = headerRow.insertCell(2);
        cell2.innerHTML = 'Vreme rute';
        cell2.style.width = '9%';
        let cell3 = headerRow.insertCell(3);
        cell3.innerHTML = 'Paket';
        cell3.style.width = '18%';
        let cell4 = headerRow.insertCell(4);
        cell4.innerHTML = 'Status';
        cell4.style.width = '10%';
        let cell5 = headerRow.insertCell(5);
        cell5.innerHTML = 'Kataloški broj';
        cell5.style.width = '18%';
        let cell6 = headerRow.insertCell(6);
        cell6.innerHTML = 'Brend';
        cell6.style.width = '15%';
        let cell7 = headerRow.insertCell(7);
        cell7.innerHTML = 'Vreme zatvaranja';
        cell7.style.width = '9%';

        const body = table.createTBody();
        groupedData.forEach(line => {
            let srcTranspRouteDescription = line.srcTranspRouteDescription !== null ? `${line.srcTranspRouteDescription}` : '';
            let srcTranspStartDateTime = line.srcTranspStartDateTime !== null ? formatTime(line.srcTranspStartDateTime) : '';
            let srcTranspCutOffDateTime = line.srcTranspCutOffDateTime !== null ? formatTime(line.srcTranspCutOffDateTime) : '';
            let creationDateTime = line.creationDateTime !== null ? formatTime(line.creationDateTime) : '';
            const cutoffDateTime = new Date(line.srcTranspCutOffDateTime);
            const now = new Date();
            let no = line.no !== null ? `${line.no}` : '';
            let status = line.status !== null ? `${line.status}` : '';
            let itemNo = line.itemNo !== null ? `${line.itemNo}` : '';
            let brend = line.itemVendorBrandCode !== null ? `${line.itemVendorBrandCode}` : '';
            const row = body.insertRow();
            if (cutoffDateTime < now){
                row.classList.add('past-date');
            }
            row.insertCell(0).innerHTML = srcTranspRouteDescription;
            row.insertCell(1).innerHTML = `${srcTranspCutOffDateTime}`;
            row.insertCell(2).innerHTML = `${srcTranspStartDateTime}`;
            row.insertCell(3).innerHTML = no;
            const statusCell = row.insertCell(4);
            statusCell.innerHTML = status;
            if (status === 'Zapakovan') {
                statusCell.classList.add('status-zapakovan');
            }
            row.insertCell(5).innerHTML = itemNo;
            row.insertCell(6).innerHTML = brend;
            row.insertCell(7).innerHTML = creationDateTime;
        });

        container.appendChild(table);
        return container.innerHTML;

    }
    function createBottomTable(groupedData) {
        const container = document.createElement('div');

        const table = document.createElement('table');
        table.classList.add('tablePackage');

        const header = table.createTHead();
        const headerRow = header.insertRow(0);
        let cell0 = headerRow.insertCell(0);
        cell0.innerHTML = 'Opis rute razvoza';
        cell0.style.width = '18%';
