@model IDAProject.Web.Admin.Models.ViewModels.WhMonitor.WhMonitorViewModel

<style type="text/css">
    .full-page-ad {
        display: none; /* Hidden by default */
        position: fixed; /* Stay in place */
        z-index: 9999; /* Sit on top */
        left: 0;
        top: 0;
        width: 100%; /* Full width */
        height: 100%; /* Full height */
        overflow: auto; /* Enable scroll if needed */
        background-color: rgba(0,0,0,0.8); /* Black w/ opacity */
        /* animation: fadeIn 0.5s ease-out; */
        /* animation-fill-mode: forwards; /* Keeps the element in the state of the last keyframe when the animation finishes */ */
        align-items: center; /* Vertical alignment */
        justify-content: center; /* Horizontal alignment */
    }

    .ad-content {
        background-color: transparent;
        margin: auto; /* 15% from the top and centered */
        padding: 20px;
        width: 95%; /* Could be more or less, depending on design */
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center; /* For centering non-flex items, if any */
    }

        .ad-content img {
            max-height: 90vh; /* 90% of the viewport height */
            width: auto; /* Maintain aspect ratio */
            max-width: 100%; /* Ensure it doesn't exceed the width of the container */
            display: block; /* Remove any default inline spacing */
            margin: auto; /* Center the image horizontally */
        }
    /* Add keyframes for fadeIn animation */
    @@keyframes fadeIn {
        from {opacity: 0;}
        to {opacity: 1;}
    }

    @@keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%); /* Start off-screen to the right */
        }

        to {
            transform: translateX(0); /* Slide to fully visible */
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0); /* Start from fully visible */
        }

        to {
            transform: translateX(-100%); /* Slide out to the left */
        }
    }
</style>

<div id="fullPageAd" class="full-page-ad">
    <div class="ad-content">
        <img src="@Model.FullPageAd" class="img-fluid" alt="Banner 1">
    </div>
</div>

<script type="text/javascript">
    // Otvori reklamu
    function openAd() {

        const adElement = document.getElementById("fullPageAd");
        const adContent = document.querySelector(".ad-content");
        adElement.style.display = "flex";
        adElement.style.animation = "fadeIn 0.5s ease-out forwards";
        adContent.style.animation = "slideIn 0.5s ease-out forwards";
    }

    // Zatvori reklamu
    function closeAd() {
        const adElement = document.getElementById("fullPageAd");
        const adContent = document.querySelector(".ad-content");

        adContent.style.animation = "slideOut 0.5s ease-in forwards"; 
        adElement.style.animation = "fadeOut 0.5s ease-in forwards";
        setTimeout(function () {
            adElement.style.display = "none"; 
        }, 500);
    }

    function autoCloseAd() {
        setTimeout(closeAd, 5000); // Adjust time as needed
    }

</script>
