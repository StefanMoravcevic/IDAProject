@model IDAProject.Web.Admin.Models.ViewModels.NavigationBaseViewModel
@using IDAProject.Web.Admin.Models.Common;
@{
    var urlLogout = Url.RouteUrl(RouteNames.Accounts_Logout);
}

<html dir="ltr" lang="en">
<head>
    <!-- META DATA -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="TMS">
    <meta name="keywords" content="TMS">
    <link rel="shortcut icon" type="image/x-icon" href="~/images/favicon.ico" />
    <title>@ViewData["Title"] - Sirius admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/whMonitor.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/icons.css" />
    <link rel="stylesheet" type="text/css" href="~/lib/sweetalert2/sweetalert2.min.css" />
    <link rel="stylesheet" type="text/css" href="~/lib/jquery-ui/jquery-ui.css" />
    <script type="text/javascript" src="~/lib/jquery/dist/jquery.min.js"></script>
    <script type="text/javascript" src="~/lib/jquery-ui/jquery-ui.js"></script>
    <script type="text/javascript" src="js/microsoft/signalr/dist/browser/signalr.js"></script>
    @await RenderSectionAsync("Styles", required: false)
    <meta http-equiv="imagetoolbar" content="no">
</head>
<body>
    <div>
        <!-- CONTAINER -->
        <div class="container-fluid p-0 full-height">
            @RenderBody()
        </div>

