							</button>
						</div>
					</div>
					<div class="collapse show" id="searchContext">
						<div class="col-md-12">
							<div class="d-flex">
								<div class="col-sm-6 col-md-6 col-lg-3">
									<tms-input type="Text" name="Keyword" id="iSearchKeyword" label="@localizer["Keyword"]" />
								</div>
							</div>
							<div class="btn-list text-end search-button-wrapper">
								<div class="form-group">
									<button class="btn btn-primary" id="buttonSearchItems">@localizer["Search"]</button>
									<button class="btn btn-primary" id="buttonResetSearchItems">@localizer["ResetSearch"]</button>
								</div>
							</div>
						</div>
					</div>
