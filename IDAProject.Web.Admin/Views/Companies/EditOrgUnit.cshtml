@model IDAProject.Web.Admin.Models.ViewModels.Companies.OrgUnitViewModel
@using IDAProject.Web.Admin.Models.Common;
@using IDAProject.Web.Models.RequestModels.MasterData;
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@inject IStringLocalizer<SharedResources> localizer
@{
    var org = Model.OrgUnit;
    var urlListOrgUnits = Url.RouteUrl(RouteNames.OrgUnits_List, new { companyId = "111" });
}
<div class="card">
    <div class="card-body">
        <div class="panel panel-primary">
            <div class="row">
                <div class="col-lg-12 col-md-12" id="orgDataContainer">
                    <div class="card">
                        <div class="card-header border-bottom">
                            <h4 class="mb-0">@localizer["Organization unit info"]</h4>
                            <tms-input type="Hidden" name="Id" id="orgUnitId" value="@org.Id" />
                            <tms-input type="Hidden" name="CompanyId" id="CompanyId" value="@org.CompanyId!" />
                        </div>
                        <div class="card-body p-0 task-edit-main">
                            <div class="row p-5 border-bottom">
                                <div class="col-sm-12 col-md-4 col-xl-4">
                                    <tms-input type="Text" name="Name" id="orgName" value="@org.Name" required="true" label="@localizer["Name"]" />
                                </div>
                                <div class="col-sm-12 col-md-4 col-xl-2">
                                    <tms-input type="Text" name="Code" id="orgCode" value="@org.Code" required="true" label="@localizer["Code"]" />
                                </div>
                            </div>
                            <div class="row p-5 border-bottom">
                                <div class="col-sm-12 col-md-4 col-xl-4">
                                    <tms-select name="ParentOrgUnitId" id="orgParentOrgUnitId" options="@Model.OrgUnits" selected-option="@org.ParentOrgUnitId" label="@localizer["Parent org unit"]" empty-option-text="@localizer["Select parent org"]..." />
                                </div>
                                <div class="col-sm-12 col-md-4 col-xl-4">
                                    <tms-select name="CompanyId" id="orgCompanyId" options="@Model.Companies" selected-option="@org.CompanyId" label="@localizer["Company"]" empty-option-text="@localizer["Select company"]..." />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="row p-5">
                    <div class="btn-list text-end">
                        <button class="btn btn-outline-danger" id="buttonCancel">@localizer["Cancel"]</button>
                        <button class="btn btn-primary" id="buttonSave">@localizer["Save"]</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <link rel="stylesheet" type="text/css" href="~/lib/select2/select2.min.css" />
}
    @section Scripts {

    <script type="text/javascript" src="~/lib/select2/select2.min.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {
            if (@Model.ReadOnly == 1) {
                $("#orgDataContainer :input").prop("disabled", true);
                $("#buttonSave").prop("disabled", true);
            }
            $("#buttonSave").click(function () {
                var $inputsContainer = $("#orgDataContainer");

                if (validateRequiredFields($inputsContainer, '@localizer["ValidationMsg"]')) {
                    var jsonData = serializeJSON($inputsContainer);
                    var companyId = $("#CompanyId").val();

                    $.ajax({
                        url: "@Url.RouteUrl(RouteNames.OrgUnits_Save)",
                        method: "POST",
                        data: jsonData,
                        success: function (response) {
                            handleActionResponseMessage(response, function () {
                                location = response.message.replace("111", companyId);
                            }, '@localizer["Error"]', '@localizer["SavedMsg"]');
                        }
                    });
                }
            });
            $("#buttonCancel").click(function () {
                var companyId = $("#CompanyId").val();
                document.location = '@urlListOrgUnits'.replace("111", companyId);
            });

        });
    </script>
}