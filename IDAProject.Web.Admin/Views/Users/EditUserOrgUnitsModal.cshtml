@model IDAProject.Web.Admin.Models.ViewModels.Users.UserViewModel;
@using IDAProject.Web.Helpers;
@using IDAProject.Web.Models.General;
@using IDAProject.Web.Admin.Models.Common;
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@inject IStringLocalizer<SharedResources> localizer

@{
    var urlUserOrgUnitCreate = Url.RouteUrl(RouteNames.UserOrgUnits_Create);
    var urlUserOrgUnitDelete = Url.RouteUrl(RouteNames.UserOrgUnits_Delete, new { id = "111" });
    var user = Model.UserData;
}
@section Scripts {
    <script type="text/javascript" src="~/lib/datatables/dataTables.select.min.js"></script>
}
<div class="row" id="editForm">
    <input type="hidden" value="@user.Id" name="Id" id="Id" />
    <div class="col-md-12">
        <label for="Username" class="">@localizer["Username"]</label>
        <input type="text" id="Username" name="Username" value="@user.UserName" inputType="input" readonly="readonly" class="form-control text-dark" />
        <div style="margin-top:20px !important; margin-bottom:0px;">
 @*            <a href="@Url.RouteUrl(RouteNames.OrgUnits_List)" target="_blank">@localizer["OrgUnit"]</a> *@
            <tms-select name="OrgUnits" options="@Model.UserOrgUnits" id="OrgUnits" />
        </div>
        <div class="btn-list">
            <button class="btn btn-primary" id="addButton">@localizer["Assign"]</button>
            <button class="btn btn-primary" id="removeButton">@localizer["Remove"]</button>
        </div>
        <div class="form-group">
            <label style="margin-top:20px; margin-bottom:0px;">@localizer["Assigned org units"]:</label>
            <table id="tableUserOrgUnits" class="table table-striped">
                <thead>
                    <tr>
                        <th style="width:10px;">@localizer["Id"]</th>
                        <th>@localizer["OrgUnit"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usr in Model.OrgUnits)
                    {
                        <tr>
                            <td>@usr.Value</td>
                            <td>@usr.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script type="text/javascript">

    $(document).ready(function () {
        $("#OrgUnits").select2({
            dropdownParent : $("#editForm")
        });

        var tableUR = $('#tableUserOrgUnits').DataTable({

            select: { style: 'single' },
            searching: false,
            paging: false,
            info: false,
        });

        $("#addButton").click(function () {
            var userId = $("#Id").val();
            var orgUnitId = $("#OrgUnits").val();
            var orgUnitName = $("#OrgUnits option:selected").text();
            if (orgUnitId > 0) {
                $.ajax({
                    url: '@urlUserOrgUnitCreate',
                    method: 'POST',
                    data: {
                        AspNetUserId : userId,
                        orgUnitId : orgUnitId
                    },
                    success: function (response) {
                        if (response.valid) {
                            tableUR.row.add(['-', orgUnitName]).draw();
                            Swal.fire({
                                icon: 'success',
                                title: '@localizer["The org unit has been assigned successfuly."]',
                            });
                        }
                        else {
                            Swal.fire({
                                icon: 'error',
                                title: '@localizer["Error"]',
                                text: response.message
                            });
                        }
                    },
                });
            }
            else {
                Swal.fire({
                    icon: 'info',
                    title: '@localizer["You must select org unit from the dropdown list."]',
                });
            }
        });
        $("#removeButton").click(function () {
            if (tableUR.rows('.selected').any()) {
                var userOrgUnitId = tableUR.row('.selected').data()[0];
                debugger
                $.ajax({
                    url: '@urlUserOrgUnitDelete'.replace("111", userOrgUnitId),
                    method: 'POST',
                    success: function (response) {
                        var rows = tableUR
                            .rows('.selected')
                            .remove()
                            .draw();
                    }
                });
            }
            else {
                Swal.fire({
                    icon: 'info',
                    title: '@localizer["You must select org unit from the dropdown list."]',
                });
            }
        });
    });
</script>
