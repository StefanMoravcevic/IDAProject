@model IDAProject.Web.Admin.Models.ViewModels.Users.UserViewModel;
@using IDAProject.Web.Helpers;
@using IDAProject.Web.Models.General;
@using IDAProject.Web.Admin.Models.Common;
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@inject IStringLocalizer<SharedResources> localizer
@{
    var urlEmailPhoneByEmployeeId = Url.RouteUrl(RouteNames.User_EmailPhone, new { employeeId = "111" });
    var user = Model.UserData;
    var userCulture = user.UserCulture == "sr-Latn" ? 1 : user.UserCulture == "sr-Cyrl" ? 2 : user.UserCulture == "en-US" ? 3 : 0;
}

<div class="row" id="editForm">
    <input type="hidden" value="@user.Id" name="Id" />
    <div class="col-md-12">
        @{
            if (user.Id == 0)
            {
                <label for="Username">@localizer["Username"]</label>
                <input type="text" id="Username" name="Username" value="@user.UserName" required class="form-control text-dark" />

                <label for="Password">@localizer["Password"]</label>
                <input type="password" id="Password" name="Password" required class="form-control text-dark" />

                <label for="RepeatPassword">@localizer["Repeat password"]</label>
                <input type="password" id="RepeatPassword" name="RepeatPassword" required class="form-control text-dark" />
                <tms-input name="active" id="active" type="CheckBox" label="@localizer["Active"]" value="true" checked="true" />
            }
            else
            {
                <label for="Username" class="">@localizer["Username"]</label>
                <input type="text" id="Username" name="Username" value="@user.UserName" readonly class="form-control text-dark" />
                <tms-input name="active" id="active" type="CheckBox" label="@localizer["Active"]" value="@user.IsActive" checked="@user.IsActive" />
            }
        }
        <tms-select name="EmployeeId" options="@Model.Employees" selected-option="@user.EmployeeId" id="EmployeeId" label="@localizer["Employee"]" empty-option-text="@localizer["Select employee"]..." />
@*         <tms-select name="PartnerId" options="@Model.Partners" selected-option="@user.PartnerId" id="PartnerId" label="@localizer["Partner"]" empty-option-text="@localizer["Select partner"]..." />
 *@        <tms-input name="EMail" id="EMail" type="Text" label="@localizer["E-mail"]" required="true" value="@user.Email" />
        <tms-input name="EmailConfirmed" id="EmailConfirmed" type="CheckBox" label="@localizer["E-mailConfirmed"]" value="@user.EmailConfirmed" checked="@user.EmailConfirmed" />
        <tms-input name="PhoneNumber" id="PhoneNumber" type="Text" label="@localizer["Phone"]" value="@user.PhoneNumber" />
        <tms-input name="PhoneNumberConfirmed" id="PhoneNumberConfirmed" type="CheckBox" label="@localizer["PhoneConfirmed"]" value="@user.PhoneNumberConfirmed" checked="@user.PhoneNumberConfirmed" />
        @* <tms-input name="UserCulture" id="UserCulture" type="Text" label="@localizer["UICulture"]" value="@user.UserCulture" /> *@
        <tms-select name="UserCulture" options="@Model.Cultures" selected-option="@userCulture" id="UserCulture" label="@localizer["UICulture"]" empty-option-text="@localizer["Select language culture"]..." />
        <tms-select name="OrgId" options="@Model.OrgUnits" selected-option="@user.OrgId" id="OrgId" label ="@localizer["Org"]" empty-option-text="@localizer["Select org unit"]..." />
        <tms-select name="PrinterId" options="@Model.Printers" selected-option="@user.PrinterId" id="PrinterId" label ="@localizer["Printer"]" empty-option-text="@localizer["Select printer"]..." />
    </div>
</div>

<script type="text/javascript">

    function loadEmailPhoneById(employeeId) {
        if (employeeId != '') {
        $.ajax({
            url: '@urlEmailPhoneByEmployeeId'.replace("111", employeeId),
            method: 'GET',
            success: function (email_phone) {
                if (employeeId != 0) {
                    $("#EMail").val(email_phone.email);
                    $("#PhoneNumber").val(email_phone.phone);
                }
                else{
                    $("#EMail").val('');
                    $("#PhoneNumber").val('');
                }
            }
        });
        }
        else {
            $("#EMail").val('');
            $("#PhoneNumber").val('');
        }
    }

    $(document).ready(function () {

        $("#EmployeeId").change(function () {
            var employeeId = $("#EmployeeId").val();
            loadEmailPhoneById(employeeId);
        });

        function ajaxPost(url) {

            var $inputsContainer = $("#editForm");

            if (validateRequiredFields($inputsContainer, '@localizer["ValidationMsg"]')) {

                var jsonData = serializeJSON($inputsContainer);
                jsonData.NormalizedEmail = $("#EMail").val().toUpperCase();
                jsonData.PhoneNumberConfirmed = $("#PhoneNumberConfirmed").prop('checked');
                jsonData.EmailConfirmed = $("#EmailConfirmed").prop('checked');
                jsonData.IsActive = $("#active").prop('checked');
                if ($("#UserCulture").val() == 0) {
                    jsonData.UserCulture = '';
                }
                else{
                    jsonData.UserCulture = $("#UserCulture option:selected").text();
                }
                $.ajax({
                    url: url,
                    method: "POST",
                    data: jsonData,
                    success: function (response) {
                        if (response.valid) {
                            Swal.fire({
                                icon: 'success',
                                title: '@localizer["User has been saved"]',
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    location = response.message;
                                }
                            });
                        }
                        else {
                            Swal.fire({
                                icon: 'error',
                                title: '@localizer["Error"]',
                                text: response.message
                            });
                        }
                    }
                });
            }
        }

        $("#editUserModal-confirm").click(function () {

            var url;
            if (@user.Id == 0) {
                if ($("#RepeatPassword").val() != $("#Password").val()) {
                    Swal.fire({
                        icon: 'info',
                        title: '@localizer["Password and Repeat password doesn't match!"]',
                    });
                }
                else {
                    url = "@Url.RouteUrl(RouteNames.User_Create)";
                    ajaxPost(url);
                }
            }
            else {
                url = "@Url.RouteUrl(RouteNames.User_Save)";
                ajaxPost(url);
            }
        });

        $("#EmployeeId").select2({
            dropdownParent: $('#editForm')
        });
        $("#PartnerId").select2({
            dropdownParent: $('#editForm')
        });

        // requiredSelect2("EmployeeId");
    });
</script>
