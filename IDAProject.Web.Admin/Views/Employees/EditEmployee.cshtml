@{
	var employee = Model.Employee;
	var templateParams = new { id = "111" };
	if (employee.Id == 0)
	{
		ViewData["Title"] = "New employee";
	}
	else
	{
		ViewData["Title"] = employee.Name + " " + employee.Surname;
	}

	var urlSearchByZipCode = Url.RouteUrl(RouteNames.GeoLocation_ZipCode_Get, new { zipCode = "111" });
	var urlCitiesByState = Url.RouteUrl(RouteNames.GeoLocation_CitiesByState_Get, new { stateId = "111" });
	var urlZipCodesByCity = Url.RouteUrl(RouteNames.GeoLocation_ZipCodesByCity_Get, new { cityId = "111" });
	var urlOrgUnitsByCompany = Url.RouteUrl(RouteNames.Employees_OrgUnitsByCompany, templateParams);
	var urlNextEmployee = Url.RouteUrl(RouteNames.Employees_NextRow, new { currentId = 111 });
	var urlPreviousEmployee = Url.RouteUrl(RouteNames.Employees_PreviousRow, new { currentId = 111 });

}
