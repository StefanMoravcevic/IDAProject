@section Styles {
	<link rel="stylesheet" type="text/css" href="~/lib/select2/select2.min.css" />
}
@section Scripts {

	<script type="text/javascript" src="~/lib/select2/select2.min.js"></script>

	<script type="text/javascript">

		function loadCitiesAndSelectById(stateId, cityId) {

			$.ajax({
				url: '@urlCitiesByState'.replace("111", stateId),
				method: 'GET',
				success: function (cities) {

					$("#empCityId :not(option:first)").remove();

					$(cities).each(function (_, city) {
						$('#empCityId').append(`<option value="${city.id}">${city.name}</option>`);
					});

					if (cityId != 0) {
						$("#empCityId").val(cityId);
					}
				}
			});
		}


		function loadOrgUnits() {

			var selectedCompanyId = $("#empCompanyId").val();

			if (selectedCompanyId == "") {
				$("#empOrgUnitId :not(option:first)").remove();
				return;
			}

			$.ajax({
				url: '@urlOrgUnitsByCompany'.replace("111", selectedCompanyId),
				method: 'GET',
				success: function (items) {

					$("#empOrgUnitId :not(option:first)").remove();

					$(items).each(function (_, item) {
						$('#empOrgUnitId').append(`<option value="${item.value}">${item.description}</option>`);
					});
				}
			});
		}

		function loadAddressByZipCode() {
			var zipCode = $("#empZipCode").val();

			if (zipCode != "") {

				$.ajax({
					url: '@urlSearchByZipCode'.replace("111", zipCode),
					method: 'GET',
					success: function (response) {
						if (response.valid) {
							var zipInfo = response.payload;

							$("#empZipCodeId").val(zipInfo.zipCodeId);
							$("#empStateId").val(zipInfo.state.id);
							loadCitiesAndSelectById(zipInfo.state.id, zipInfo.city.id);
						}
					}
				});
			}
		}


		var fileInput = document.getElementById("fileInput");
		var imageElement = document.getElementById("Photo");
		fileInput.addEventListener("change", function (event) {
			var file = event.target.files[0];
			var reader = new FileReader();
			reader.onload = function (e) {
				imageElement.src = e.target.result;
			};
			reader.readAsDataURL(file);
		});



		$(document).ready(function () {

			let currentId = $("#empId").val();

			$("#EmployeePrevious").click(function () {
				$.ajax({
					url: `@urlPreviousEmployee`.replace('111', currentId),
					method: "GET",
					success: function (response) {
						if (response.valid) {
							currentId = response.payload.id;
							$("#empName").val(response.payload.name);
							$("#empMiddleName").val(response.payload.middleName);
							$("#empSurname").val(response.payload.surName);
							$("#empGenderId").val(response.payload.genderId);
							$("#empJobTypeId").val(response.payload.jobTypeId);
							$("#empEmail").val(response.payload.email);
							$("#empHousePhoneNumber").val(response.payload.housePhoneNumber);
							$("#empCellPhoneNumber").val(response.payload.cellPhoneNumber);
							$("#empNoticeTypeId").val(response.payload.noticeTypeId);
							$("#empCompanyId").val(response.payload.companyId);
							$("#empOrgUnitId").val(response.payload.orgUnitId);
							$("#empPersonalID").val(response.payload.personalId);
							$("#empPassportID").val(response.payload.passportId);
							$("#empInsuranceNumber").val(response.payload.insuranceNumber);
							$("#empBankAccount").val(response.payload.bankAccount);
							$("#empBankAccountAddition").val(response.payload.bankAccount);
							$("#empBankAccount").val(response.payload.bankAccountAddition);
							$("#empBankAccount").val(response.payload.bankAccountAddition);
							$("#empBirthDate").val(response.payload.birthDate);
							$("#empBirthPlace").val(response.payload.birthPlace);
							$("#empCitizenship").val(response.payload.citizenship);

							let newUrl = window.location.protocol + "//" + window.location.host + '/Employees/edit/' + currentId;
							history.pushState({ path: newUrl }, '', newUrl);

							location.reload();

						}
					},
					error: function (xhr, status, error) {
						alert("An error occurred while fetching the next order: " + error);
					}
				});
			});


			$("#EmployeeNext").click(function () {
				$.ajax({
					url: `@urlNextEmployee`.replace('111', currentId),
					method: "GET",
					success: function (response) {
						if (response.valid) {
							currentId = response.payload.id;
							$("#empName").val(response.payload.name);
							$("#empMiddleName").val(response.payload.middleName);
							$("#empSurname").val(response.payload.surName);
							$("#empGenderId").val(response.payload.genderId);
							$("#empJobTypeId").val(response.payload.jobTypeId);
							$("#empEmail").val(response.payload.email);
							$("#empHousePhoneNumber").val(response.payload.housePhoneNumber);
							$("#empCellPhoneNumber").val(response.payload.cellPhoneNumber);
							$("#empNoticeTypeId").val(response.payload.noticeTypeId);
							$("#empCompanyId").val(response.payload.companyId);
							$("#empOrgUnitId").val(response.payload.orgUnitId);
							$("#empPersonalID").val(response.payload.personalId);
							$("#empPassportID").val(response.payload.passportId);
							$("#empInsuranceNumber").val(response.payload.insuranceNumber);
							$("#empBankAccount").val(response.payload.bankAccount);
							$("#empBankAccountAddition").val(response.payload.bankAccount);
							$("#empBankAccount").val(response.payload.bankAccountAddition);
							$("#empBankAccount").val(response.payload.bankAccountAddition);
							$("#empBirthDate").val(response.payload.birthDate);
							$("#empBirthPlace").val(response.payload.birthPlace);
							$("#empCitizenship").val(response.payload.citizenship);

							let newUrl = window.location.protocol + "//" + window.location.host + '/Employees/edit/' + currentId;
							history.pushState({ path: newUrl }, '', newUrl);

							location.reload();

						}
					},
					error: function (xhr, status, error) {
						alert("An error occurred while fetching the next order: " + error);
					}
				});
			});

			if (@Model.ReadOnly == 1) {
				$("#tabGeneral :input").prop("disabled", true);
				$("#buttonCancel").prop("disabled", false);
			}

			$("#empZipCode").blur(loadAddressByZipCode);

			$("#empZipCode").keypress(function (event) {
				var zipCode = $("#empZipCode").val();
				if (event.which == 13 || zipCode.length == 5) {
					event.preventDefault();
					loadAddressByZipCode();
				}
			});

			$("#empStateId").change(function () {
				var stateId = $("#empStateId").val();
				loadCitiesAndSelectById(stateId, 0);
			});

			$("#buttonSave").click(function () {
				var $inputsContainer = $("#tabGeneral");

				if (validateRequiredFields($inputsContainer)) {

					var jsonData = serializeJSON($inputsContainer);
					var imageElement = document.getElementById("Photo");
					var base64Image = imageElement.src
					jsonData.Photo = base64Image;
					$.ajax({
						url: "@Url.RouteUrl(RouteNames.Employees_Save)",
						method: "POST",
						data: jsonData,
						success: function (response) {
							handleActionResponseMessage(response, function () {
								location = response.message;
							}, '@localizer["Error"]', '@localizer["SavedMsg"]');
						}
					});
				}
			});

			$("#empCompanyId").change(loadOrgUnits);
			$("#empGenderId").select2({

			});

			$("#empGenderId").select2({
			});
			$("#empJobTypeId").select2({
			});
			$("#empNoticeTypeId").select2({
			});
			$("#empCompanyId").select2({
			});
			$("#empOrgUnitId").select2({
			});
			$("#StateId").select2({
			});
			$("#CityId").select2({
			});
			$("#ZipCodeId").select2({
			});


			$("#buttonCancel").click(function () {
				var jobTypeId = $("#empJobTypeId").val();
				document.location = '@Url.RouteUrl(RouteNames.Employees_List)';
			});

		});
	</script>
}