@model IDAProject.Web.Admin.Models.ViewModels.Employees.EmployeesViewModel
@using IDAProject.Web.Admin.Models.Common;
@using IDAProject.Web.Models.General.Enums
@using IDAProject.Web.Models.RequestModels.MasterData;
@using IDAProject.Web.Admin.Models.TagHelpers;
@using NPOI.SS.Formula.Functions
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> localizer
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin

@{
	//if (Model.JobTypeId == 0)
	//{
	//    Model.JobTypeId = JobTypes.Company_driver;
	//};

	//var jobTypeDescription = JobTypes.GetDescription(Model.JobTypeId);
	//ViewData["Title"] = $"Employees - {jobTypeDescription}";
	ViewData["Title"] = $"Employees";
	var localizedPagination = @Html.Raw(Json.Serialize(new PaginationLocalizerModel(localizer)));
	var urlDelete = Url.RouteUrl(RouteNames.Employees_Delete, new { id = 111 });
	var urlNextEmployee = Url.RouteUrl(RouteNames.Employees_NextRow, new { currentId = 111 });
	var urlPreviousEmployee = Url.RouteUrl(RouteNames.Employees_PreviousRow, new { currentId = 111 });


}
<style>
	#tableEmployees tbody tr {
		cursor: pointer !important;
	}
</style>
<div class="row">
	<div class="col-lg-12 col-md-12">
		<div class="card">
			<div class="card-header border-bottom">
				<h4 class="mb-0">@localizer["Staff"]</h4>
			</div>
		</div>
	</div>
</div>
<div class="row">
	<div class="col-md-12 text-end">
		<button class="btn btn-link" type="button" data-bs-toggle="collapse" data-bs-target="#employeeCollapse" aria-expanded="true" aria-controls="employeeCollapse" style="background-color:white;">
			<i class="fa fa-expand" id="showContext" style="color:black;"></i>
		</button>
	</div>
</div>
<div class="row">
	<div class="col-md-12">
		<partial name="ContextOptionsPartial" model="@Model" />
	</div>
</div>
<div class="row row-sm">
	<div class="col-lg-12">
		<div class="card">
			<div class="card-body" style="overflow-x:auto">
				<tms-ajax-table id="tableEmployees" view-model="@Model" table-settings-reference-table="Employees" />
			</div>
		</div>
	</div>
</div>
<tms-modal id="editDispatchersAssignment" title="Edit" save-button="false" modal-size="@ModalSize.ExtraLarge" />
<tms-modal id="dispatcherDriversList" title="" save-button="false" modal-size="@ModalSize.ExtraLarge" />
