@model IDAProject.Web.Admin.Models.ViewModels.IDA.IDAViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@using IDAProject.Web.Admin.Models.Common;
@using IDAProject.Web.Models.RequestModels.MasterData;
@using IDAProject.Web.Helpers;
@using IDAProject.Web.Admin.Models.TagHelpers;
@using IDAProject.Web.Admin.Models.TagHelpers.Base;
@using IDAProject.Web.Admin.TagHelpers.Base;
@inject IStringLocalizer<SharedResources> localizer
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@{
	ViewData["Title"] = "IDA";
	var planNewDay = Url.RouteUrl(RouteNames.IDA_PlanNewDay);
	var employeePlaceholderParam = new { employeeId = 111 };
	var urlPatternAbsences = Url.RouteUrl(RouteNames.EmployeeAbsences_ListByEmployeeId, employeePlaceholderParam);
}
<style>
	.page-main::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5); /* 0.5 = jačina tame */

		z-index: 0;
	}

	.page-main {
		position: relative;
	}

		.page-main::before {
			pointer-events: none;
			z-index: 0;
		}

	.card {
		border-radius: 12px;
	}

	.card-header {
		border-top-left-radius: 12px;
		border-top-right-radius: 12px;
	}

	.tooltip-target {
		cursor: pointer;
	}

	.table {
		font-size: 14px;
	}

		.table th {
			background: #f8f9fa;
		}

	.table-hover tbody tr:hover {
		background: #f1f5ff;
	}

	#manualTable {
		border-radius: 8px;
		overflow: hidden;
	}

	#manualTable {
		table-layout: fixed;
		width: 100%;
	}

	.custom-tooltip {
		position: absolute;
		background: #333;
		color: white;
		padding: 6px 10px;
		border-radius: 4px;
		font-size: 12px;
		display: none;
		z-index: 9999;
		pointer-events: none;
		white-space: nowrap;
	}

	/* Modernija tabela */
	

		#manualTable th,
		#manualTable td {
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

			/* Širine po kolonama */
			#manualTable th:nth-child(1),
			#manualTable td:nth-child(1) {
				width: 15%;
			}

			#manualTable th:nth-child(2),
			#manualTable td:nth-child(2) {
				width: 15%;
			}

			#manualTable th:nth-child(3),
			#manualTable td:nth-child(3) {
				width: 15%;
			}

			/* Od */
			#manualTable th:nth-child(4),
			#manualTable td:nth-child(4) {
				width: 8%;
			}

			/* Do */
			#manualTable th:nth-child(5),
			#manualTable td:nth-child(5) {
				width: 8%;
			}

			/* Trajanje */
			#manualTable th:nth-child(6),
			#manualTable td:nth-child(6) {
				width: 8%;
			}

			/* Redni broj */
			#manualTable th:nth-child(7),
			#manualTable td:nth-child(7) {
				width: 15%;
			}

		#manualTable select.form-select {
			width: 100%;
		}

		#manualTable td {
			padding: 4px;
		}
</style>
<tms-modal id="editAbsenceModal" title="@localizer["Absences"]" save-button="false" modal-size="@ModalSize.Large" />
<div class="container-fluid mt-1">

	<!-- ========================= -->
	<!-- GORNJI DEO: SLIKA + PLAN TABELA -->
	<!-- ========================= -->
	<div class="row g-2">

		<!-- SLIKA -->
		<div class="col-md-2">
			<div class="card shadow-sm mb-3">
				<div class="card-header bg-light fw-bold">
					@localizer["Users photo"]
				</div>
				<div class="card-body text-center">
					@if (!string.IsNullOrEmpty(Model.ImageSource))
					{
						<img src="@Model.ImageSource"
							 class="img-fluid rounded"
							 style="max-height:150px;"
							 alt="Task image" />
					}
					else
					{
						<p class="text-muted">@localizer["No image available"]</p>
					}
				</div>
			</div>
		</div>

		<!-- PLAN TABELA (FULL WIDTH OSTATAK) -->
		<div class="col-md-10">

			<div class="card shadow-lg border-0 rounded-3">
				<div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center">
					<span>📅 @localizer["Plans for day"] @Model.Today</span>

					<select id="activityMode" name="ActivityTypePlanId" class="form-select form-select-sm w-auto">
						<option value="">@localizer["Select activity type"]</option>
						<option value="1">@localizer["Project"]</option>
						<option value="2">@localizer["Task"]</option>
						<option value="3">@localizer["Regular activity"]</option>
					</select>
				</div>

				<div class="card-body p-3">

					<div class="table-responsive">
						<table class="table table-hover table-bordered align-middle" id="manualTable">
							<thead id="dynamicTableHead" class="table-light">
								<tr>
									<th class="text-center text-muted">
										@localizer["Select activity type to generate table"]
									</th>
								</tr>
							</thead>
							<tbody></tbody>
						</table>
					</div>

					<button class="btn btn-success btn-sm px-3 mt-2" id="btnAddRow">
						➕ @localizer["Add row"]
					</button>

				</div>
			</div>

		</div>
	</div>

	<!-- ========================= -->
	<!-- ACTIVITIES (BUTTONS + PLAN/REAL) -->
	<!-- ========================= -->
	<div class="card shadow-sm mt-3">

		<div class="card-header fw-bold" style="background-color:#fabb3e; color:white;">
			📝 @localizer["Activities"]
		</div>

		<div class="card-body">

			<!-- DUGMAD IZNAD KOLONA -->
			<div class="d-flex gap-2 mb-3">
				<button class="btn btn-primary btn-sm" id="btnPlanNewDay">
					🔄 @localizer["Plan new day"]
				</button>

				<button class="btn btn-primary btn-sm" id="btnEnterAbsence">
					📊 @localizer["Enter absence"]
				</button>
			</div>

			<div class="row">

				<!-- PLAN -->
				<div class="col-md-5">
					<h6 class="fw-bold">📌 @localizer["Yours today plans"]</h6>

					<div class="table-responsive">
						<table class="table table-modern" id="plannedTable">
							<thead>
								<tr>
									<th>@localizer["Your task"]</th>
									<th>@localizer["Plan no"]</th>
									<th>@localizer["Activity"]</th>
									<th>@localizer["Time from"]</th>
									<th>@localizer["Time to"]</th>
									<th>@localizer["Duration"]</th>
									<th>@localizer["Status"]</th>
									<th>@localizer["Finished"]</th>
								</tr>
							</thead>
							<tbody></tbody>
						</table>
					</div>

					<div class="mt-3 d-flex justify-content-center">
						<div style="width: 320px;">
							<canvas id="planPieChart"></canvas>
						</div>
					</div>
				</div>

				<!-- REALISATION -->
				<div class="col-md-7 border-start" style="border-color:#ddd !important;">
					<h6 class="fw-bold">✅ @localizer["Yours today realisation"]</h6>

					<div class="table-responsive">
						<table class="table table-modern" id="realizedTable">
							<thead class="table-light">
								<tr>
									<tr>
										<th>@localizer["Plan no"]</th>
										<th class="col-activityType">@localizer["Activity type"]</th>
										<th class="col-taskName">@localizer["Task"]</th>

										<th class="col-project" style="display:none;">@localizer["Project"]</th>
										<th class="col-task" style="display:none;">@localizer["Task"]</th>
										<th class="col-regular" style="display:none;">@localizer["Regular activity"]</th>

										<th>@localizer["Activity"]</th>
										<th>@localizer["Time from"]</th>
										<th>@localizer["Time to"]</th>
										<th>@localizer["Duration"]</th>
										<th>@localizer["Report"]</th>
										<th>@localizer["Finished"]</th>
										<th>@localizer["Actions"]</th>
									</tr>
								</tr>
							</thead>
							<tbody></tbody>
						</table>
					</div>

					<button class="btn btn-primary btn-sm mt-2" id="btnAddRealRow">
						➕ @localizer["Add row"]
					</button>
					<div class="mt-3 d-flex justify-content-center">
						<div style="width: 320px;">
							<canvas id="realizationPieChart"></canvas>
						</div>
					</div>
				</div>
									

			</div>
		</div>
	</div>

	<!-- ========================= -->
	<!-- TASK SEKCIJE ISPOD -->
	<!-- ========================= -->
	<div class="row mt-4">

		<div class="col-12">

			<!-- NOVI ZADATAK -->
			<div class="mb-4" style="max-width:420px;">
				<div class="card shadow-sm p-4" id="taskDataContainer">
					<h5 class="mb-2">@localizer["Enter new task"]</h5>

					<div class="mb-1">
						<tms-input type="Text" name="Name" id="taskName" class="form-control"
								   label="@localizer["Task name"]:"
								   placeholder="@localizer["Enter task name"]..." />
					</div>

					<div class="mb-1">
						<tms-input type="Date" name="DueDate" id="taskDueDate" class="form-control"
								   label="@localizer["Task due date"]:"
								   placeholder="@localizer["Enter task due date"]..." />
					</div>

					<button id="saveTask" class="btn btn-success w-100">
						@localizer["Save"]
					</button>
				</div>
			</div>

			<!-- TASK TABLE -->
			<div class="mb-4" style="max-width:420px;">
				<div class="card shadow-sm">
					<div class="card-header bg-light"
						 data-bs-toggle="collapse"
						 data-bs-target="#taskTableCollapse"
						 style="cursor:pointer;">
						@localizer["Click for showing/hiding tasks"]
					</div>

					<div id="taskTableCollapse" class="collapse">
						<div class="card-body p-2">
							<table class="table table-sm table-striped" id="tasksTable">
								<thead>
									<tr>
										<th>@localizer["Name"]</th>
										<th>@localizer["Due Date"]</th>
									</tr>
								</thead>
								<tbody></tbody>
							</table>
						</div>
					</div>
				</div>
			</div>

			<!-- PROJECT TASK -->
			<div class="mb-4" style="max-width:420px;">
				<div class="card shadow-sm p-4" id="projectTaskDataContainer">
					<h5 class="mb-2">@localizer["Enter new project task"]</h5>

					<div class="mb-1">
						<tms-select name="ProjectId" id="ProjectId" options="@Model.Projects"
									label="@localizer["Project"]:"
									empty-option-text="@localizer["Select project"]..." />
					</div>

					<div class="mb-1">
						<tms-input type="Text" name="Name" id="projectTaskName" class="form-control"
								   label="@localizer["Task name"]:"
								   placeholder="@localizer["Enter task name"]..." />
					</div>

					<div class="mb-1">
						<tms-input type="Date" name="DueDate" id="projectTaskDueDate" class="form-control"
								   label="@localizer["Task due date"]:"
								   placeholder="@localizer["Enter task due date"]..." />
					</div>

					<button class="btn btn-success w-100" id="saveProjectTask">
						@localizer["Save"]
					</button>
				</div>
			</div>

			<!-- REGULAR ACTIVITY -->
			<div class="mb-4" style="max-width:420px;">
				<div class="card shadow-sm p-4" id="regularActivityDataContainer">
					<h5 class="mb-2">@localizer["Enter new regular activity"]</h5>

					<div class="mb-1">
						<tms-input type="Text" name="Name" id="regularActivityName" class="form-control"
								   label="@localizer["Regular activity name"]:"
								   placeholder="@localizer["Enter regular activity name"]..." />
					</div>

					<button class="btn btn-success w-100" id="saveRegularActivity">
						@localizer["Save"]
					</button>
				</div>
			</div>

		</div>
	</div>

</div>
<div id="customTooltip" class="custom-tooltip"></div>
@section Styles {
	<link rel="stylesheet" type="text/css" href="~/lib/select2/select2.min.css" />
}
@section Scripts {

	<script type="text/javascript" src="~/lib/select2/select2.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>

	<script type="text/javascript">
			let planPieChart = null;
			let realizationPieChart = null;
			const activityTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ActivityTypes));
			const projects = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Projects));
			const tasks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Tasks));
			const projectTasks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProjectTasks));
			const statuses = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PlanStatuses));
			var plannedTasks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TaskPlannings));

			function searchTaskPlanningsNumbersForRealization() {

				$.ajax({
					url: "@Url.RouteUrl(RouteNames.TasksPlannings_Search)",
					method: "POST",
					data: {
						createdDate: "@Model.Today",
						userId: "@Model.User.Id"
					},
					success: function (data) {

						plannedTasks.length = 0; // očisti prethodne

						// Popuni sa stvarnim planovima
						data.forEach(item => {
							plannedTasks.push({
								Value: item.id,
								Description: item.planNo
							});
						});

						// Dodaj opciju sa 0
						plannedTasks.push({
							Value: 0,
							Description: "0"
						});

						console.log(plannedTasks);
					},
					error: function (err) {
						console.log(err);
					}
				});
			}

			  $("#activityMode").change(function () {

				  let mode = $(this).val();
				  let thead = $("#dynamicTableHead");
				  let tbody = $("#manualTable tbody");

				  thead.empty();
				  tbody.empty();

				  if (!mode) {
					  thead.append(`
						  <tr>
							  <th class="text-center text-muted">
								  @localizer["Select activity type to generate table"]
							  </th>
						  </tr>
					  `);
					  return;
				  }

				  if (mode === "1") {
					  thead.append(`
						  <tr>
							  <th>@localizer["Project"]</th>
							  <th>@localizer["Task"]</th>
							  <th>@localizer["Activity"]</th>
							  <th>@localizer["From"]</th>
							  <th>@localizer["to"]</th>
							  <th>@localizer["Duration"]</th>
							  <th>@localizer["Order number"]</th>
							  <th>@localizer["Status"]</th>
							  <th>@localizer["Actions"]</th>
						  </tr>
					  `);
				  }

				  if (mode === "2") {
					  thead.append(`
						  <tr>
							  <th>@localizer["Task"]</th>
							  <th>@localizer["Activity"]</th>
							  <th>@localizer["From"]</th>
							  <th>@localizer["to"]</th>
							  <th>@localizer["Duration"]</th>
							  <th>@localizer["Order number"]</th>
							  <th>@localizer["Status"]</th>
							  <th>@localizer["Actions"]</th>
						  </tr>
					  `);
				  }

				  if (mode === "3") {
					  thead.append(`
						  <tr>
							  <th>@localizer["Regular activity"]</th>
							  <th>@localizer["Activity"]</th>
							  <th>@localizer["From"]</th>
							  <th>@localizer["to"]</th>
							  <th>@localizer["Duration"]</th>
							  <th>@localizer["Order number"]</th>
							  <th>@localizer["Status"]</th>
							  <th>@localizer["Actions"]</th>
						  </tr>
					  `);
				  }

			  });

			$("#btnAddRow").click(function () {

			let mode = $("#activityMode").val();
			let tbody = $("#manualTable tbody");

			if (!mode) {
				Swal.fire({
					icon: 'warning',
					title: '@localizer["Select activity type first"]',
					confirmButtonText: '@localizer["OK"]'
				});
				return;
			}

			let newRowHtml = "";

			// ================= MODE 1 =================
			if (mode === "1") {

				newRowHtml = `
				<tr>
					<td>
						<select class="form-select form-select-sm" name="ProjectId">
							<option value="">@localizer["Select project"]</option>
							@foreach (var p in Model.Projects)
							{
									<option value="@p.Value">@p.Description</option>
							}
						</select>
					</td>
					<td>
						<select class="form-select form-select-sm" name="TaskId">
							<option value="">@localizer["Select task"]</option>
							@foreach (var t in Model.ProjectTasks)
							{
									<option value="@t.Value">@t.Description</option>
							}
						</select>
					</td>
					<td>
						<input class="form-control form-control-sm" name="ActivityName"
							   placeholder="@localizer["Activity"]">
					</td>
					<td><input type="text" class="form-control form-control-sm from-time timepicker" name="TimeFromFormatted"></td>
					<td><input type="text" class="form-control form-control-sm to-time timepicker" name="TimeToFormatted"></td>
					<td><input class="form-control form-control-sm duration" readonly name="DurationFormatted"></td>

					<!-- 🔥 AUTOMATSKI REDNI BROJ -->
					<td><input type="number" class="form-control form-control-sm" name="PlanNo" readonly></td>

					<td>
						<select class="form-select form-select-sm" name="PlanStatusId">
							<option value="">@localizer["Select status"]</option>
							@foreach (var s in Model.PlanStatuses)
							{
									<option value="@s.Value">@s.Description</option>
							}
						</select>
					</td>
					<td class="text-center">
						<button type="button" class="btn btn-sm btn-success saveRow">💾</button>
					</td>
				</tr>`;
			}

			// ================= MODE 2 =================
			if (mode === "2") {

				newRowHtml = `
				<tr>
					<td>
						<select class="form-select form-select-sm" name="TaskId">
							<option value="">@localizer["Select task"]</option>
							@foreach (var r in Model.Tasks)
							{
									<option value="@r.Value">@r.Description</option>
							}
						</select>
					</td>
					<td>
						<input class="form-control form-control-sm" name="ActivityName"
							   placeholder="@localizer["Activity"]">
					</td>
					<td><input type="text" class="form-control form-control-sm from-time timepicker" name="TimeFromFormatted"></td>
					<td><input type="text" class="form-control form-control-sm to-time timepicker" name="TimeToFormatted"></td>
					<td><input class="form-control form-control-sm duration" readonly name="DurationFormatted"></td>

					<!-- 🔥 AUTOMATSKI REDNI BROJ -->
					<td><input type="number" class="form-control form-control-sm" name="PlanNo" readonly></td>

					<td>
						<select class="form-select form-select-sm" name="PlanStatusId">
							<option value="">@localizer["Select status"]</option>
							@foreach (var s in Model.PlanStatuses)
							{
									<option value="@s.Value">@s.Description</option>
							}
						</select>
					</td>
					<td class="text-center">
						<button type="button" class="btn btn-sm btn-success saveRow">💾</button>
					</td>
				</tr>`;
			}

			// ================= MODE 3 =================
			if (mode === "3") {

				newRowHtml = `
				<tr>
					<td>
						<select class="form-select form-select-sm" name="RegularActivityId">
							<option value="">@localizer["Select regular activity"]</option>
							@foreach (var r in Model.RegularActivities)
							{
									<option value="@r.Value">@r.Description</option>
							}
						</select>
					</td>
					<td>
						<input class="form-control form-control-sm" name="ActivityName"
							   placeholder="@localizer["Activity"]">
					</td>
					<td><input type="text" class="form-control form-control-sm from-time timepicker" name="TimeFromFormatted"></td>
					<td><input type="text" class="form-control form-control-sm to-time timepicker" name="TimeToFormatted"></td>
					<td><input class="form-control form-control-sm duration" readonly name="DurationFormatted"></td>

					<!-- 🔥 AUTOMATSKI REDNI BROJ -->
					<td><input type="number" class="form-control form-control-sm" name="PlanNo" readonly></td>

					<td>
						<select class="form-select form-select-sm" name="PlanStatusId">
							<option value="">@localizer["Select status"]</option>
							@foreach (var s in Model.PlanStatuses)
							{
									<option value="@s.Value">@s.Description</option>
							}
						</select>
					</td>
					<td class="text-center">
						<button type="button" class="btn btn-sm btn-success saveRow">💾</button>
					</td>
				</tr>`;
			}

			// APPEND ROW
			tbody.append(newRowHtml);

			// INIT TIMEPICKER NA NOVOM REDU
			let newRow = tbody.find("tr:last");
			initTimePickers(newRow);
			newRow.find("select[name='PlanStatusId']").val("1");
			getLastPlanNo(function (lastNo) {
				newRow.find("input[name='PlanNo']").val(lastNo + 1);
			});
		});

		function updateColumnsByActivityType(activityTypeId, row) {
    // Sakrij sve kolone (td i th)
			$(".col-project, .col-task, .col-regular").hide();

			// Prikazi odgovarajuce kolone
			if (activityTypeId == 1) { // Project
				row.find("select[name='ProjectId'], select[name='TaskId']").val(""); // reset polja ako je potrebno
				$(".col-project, .col-task").css('display','table-cell');
			}
			else if (activityTypeId == 2) { // Task
				row.find("select[name='TaskId']").val("");
				$(".col-task").css('display','table-cell');
			}
			else if (activityTypeId == 3) { // Regular activity
				row.find("select[name='RegularActivityId']").val("");
				$(".col-regular").css('display','table-cell');
			}
		}

			function initTimePickers(container) {

				$(container).find('.timepicker').each(function () {

					if (!this._airDatepicker) {
						new AirDatepicker(this, {
							timepicker: true,
							onlyTimepicker: true,
							timeFormat: 'HH:mm',
							autoClose: true,
							buttons: false,
							minutesStep: 5,
							onSelect: function () {
							$(this.$el).trigger("change");
						},

						// 🔥 kad se zatvori picker (fallback)
						onClose: function () {
							$(this.$el).trigger("change");
						}
						});
					}

				});
			}
			function renderPlanPieChart(stats) {

				let ctx = document.getElementById('planPieChart').getContext('2d');

				let total = Object.values(stats).reduce((a, b) => a + b, 0);

				if (planPieChart) {
					planPieChart.destroy();
				}

				planPieChart = new Chart(ctx, {
					type: 'pie',
					data: {
						labels: Object.keys(stats),
						datasets: [{
							data: Object.values(stats)
						}]
					},
					options: {
						responsive: true,
						plugins: {
							legend: {
								display: true,
								position: 'bottom'
							},
							datalabels: {
								color: '#fff',
								formatter: function (value) {
									if (!total) return '0%';
									let percent = ((value / total) * 100).toFixed(1);
									return percent + '%';
								},
								font: {
									weight: 'bold',
									size: 14
								}
							}
						}
					},
					plugins: [ChartDataLabels]
				});
			}
