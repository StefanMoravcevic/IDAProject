			function calculateRowDuration(row) {

				let from = row.find(".from-time").val();
				let to = row.find(".to-time").val();

				if (!from || !to) {
					row.find(".duration").val("");
					return;
				}

				let fromParts = from.split(":");
				let toParts = to.split(":");

				if (fromParts.length !== 2 || toParts.length !== 2) {
					row.find(".duration").val("");
					return;
				}

				let fromMinutes = parseInt(fromParts[0]) * 60 + parseInt(fromParts[1]);
				let toMinutes = parseInt(toParts[0]) * 60 + parseInt(toParts[1]);

				let diff = toMinutes - fromMinutes;

				if (diff < 0) {
					row.find(".duration").val("Invalid");
					return;
				}

				let hours = Math.floor(diff / 60);
				let minutes = diff % 60;

				let formatted =
					String(hours).padStart(2, '0') +
					":" +
					String(minutes).padStart(2, '0');

				row.find(".duration").val(formatted);
			}

			  function searchTasks() {
				  $.ajax({
					  url: "@Url.RouteUrl(RouteNames.IdaTasks_Search)",
					  method: "POST",
					  success: function (response) {

						  var rows = "";

						  $.each(response, function (i, task) {

							  var dueDate = "";
							  if (task.dueDate) {
								  var date = new Date(task.dueDate);
								  dueDate = date.toLocaleDateString("sr-RS");
							  }

							  rows += "<tr>";
							  rows += "<td>" + task.name + "</td>";
							  rows += "<td>" + dueDate + "</td>";
							  rows += "</tr>";
						  });

						  $("#tasksTable tbody").html(rows);

						  // PRIKAŽI COLLAPSE TABELU
						  $("#taskTableCollapse").collapse("show");
					  },
					  error: function () {
						  alert("Greška pri učitavanju zadataka.");
					  }
				  });
			  }

