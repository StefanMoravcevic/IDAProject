			function getLastPlanNo(callback) {

				$.ajax({
					url: "@Url.RouteUrl(RouteNames.TasksPlannings_Search)",
					method: "POST",
					data: {
						createdDate: "@Model.Today",
						userId: "@Model.User.Id"
					},
					success: function (data) {

						let last = 0;

						if (data && data.length > 0) {
							last = Math.max(...data.map(x => parseInt(x.planNo) || 0));
						}

						callback(last);
					},
					error: function () {
						callback(0);
					}
				});
			}

