			function getLastPlanNo(callback) {

				$.ajax({
					url: "@Url.RouteUrl(RouteNames.TasksPlannings_Search)",
					method: "POST",
					data: {
						createdDate: "@Model.Today",
						userId: "@Model.User.Id"
					},
					success: function (data) {

						let last = 0;

						if (data && data.length > 0) {
							last = Math.max(...data.map(x => parseInt(x.planNo) || 0));
						}

						callback(last);
					},
					error: function () {
						callback(0);
					}
				});
			}

		function searchTaskPlanningsPopulateTable() {

				$.ajax({
					url: "@Url.RouteUrl(RouteNames.TasksPlannings_Search)",
					method: "POST",
					data: {
						createdDate: "@Model.Today",
						userId: "@Model.User.Id"
					},
					success: function (data) {

						let tbody = $("#plannedTable tbody");
						tbody.empty();

						let stats = {};

						$.each(data, function (index, item) {

							// ===== FINISHED IKONICA =====
							let finishedIcon = '';

							if (item.isFinished === null) {
								finishedIcon = '-';
							}
							else if (item.isFinished === true) {
								finishedIcon = '<span style="color:green; font-weight:bold;">✔</span>';
							}
							else {
								finishedIcon = '<span style="color:red; font-weight:bold;">✖</span>';
							}

							let row = `
							<tr data-id="${item.id}" class="tooltip-target" data-tooltip="@localizer["Click for change"]">
								<td>${item.displayTask ?? ""}</td>
								<td>${item.planNo ?? ""}</td>
								<td>${item.activityName ?? ""}</td>
								<td>${item.timeFromFormatted}</td>
								<td>${item.timeToFormatted}</td>
								<td>${item.durationFormatted ?? ""}</td>
								<td>${item.planStatus}</td>
								<td class="text-center">${finishedIcon}</td>
							</tr>`;

							tbody.append(row);

							// ===== STATS ZA PIE =====
							let type = item.activityTypeName ?? "Unknown";
							stats[type] = (stats[type] || 0) + 1;
						});

						// ===== NE TREBA BOOTSTRAP TOOLTIP RESET =====
						// (ako koristiš custom tooltip)

						// ===== RENDER PIE CHART =====
						renderPlanPieChart(stats);
					},
					error: function (err) {
						console.log(err);
					}
				});
			}

