@model IDAProject.Web.Admin.Models.ViewModels.IDA.IDAViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@using IDAProject.Web.Admin.Models.Common;
@using IDAProject.Web.Models.RequestModels.MasterData;
@using IDAProject.Web.Helpers;
@inject IStringLocalizer<SharedResources> localizer
@addTagHelper IDAProject.Web.Admin.TagHelpers.*, IDAProject.Web.Admin
@{
    ViewData["Title"] = "IDA";
}
<style>
    .page-main::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5); /* 0.5 = jačina tame */

        z-index: 0;
    }

    .page-main {
        position: relative;
    }

        .page-main::before {
            pointer-events: none;
            z-index: 0;
        }

    .card {
        border-radius: 12px;
    }

    .card-header {
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }

    .table {
        font-size: 14px;
    }

        .table th {
            background: #f8f9fa;
        }

    .table-hover tbody tr:hover {
        background: #f1f5ff;
    }

    #manualTable {
        border-radius: 8px;
        overflow: hidden;
    }

    #manualTable {
        table-layout: fixed;
        width: 100%;
    }

        #manualTable th,
        #manualTable td {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

            /* Širine po kolonama */
            #manualTable th:nth-child(1),
            #manualTable td:nth-child(1) {
                width: 15%;
            }

            #manualTable th:nth-child(2),
            #manualTable td:nth-child(2) {
                width: 15%;
            }

            #manualTable th:nth-child(3),
            #manualTable td:nth-child(3) {
                width: 15%;
            }

            /* Od */
            #manualTable th:nth-child(4),
            #manualTable td:nth-child(4) {
                width: 8%;
            }

            /* Do */
            #manualTable th:nth-child(5),
            #manualTable td:nth-child(5) {
                width: 8%;
            }

            /* Trajanje */
            #manualTable th:nth-child(6),
            #manualTable td:nth-child(6) {
                width: 8%;
            }

            /* Redni broj */
            #manualTable th:nth-child(7),
            #manualTable td:nth-child(7) {
                width: 8%;
            }

        #manualTable select.form-select {
            width: 100%;
        }

        #manualTable td {
            padding: 4px;
        }
 

</style>
<div class="container-fluid mt-4">

    <div class="row g-2">

        <!-- ========================= -->
        <!-- LEVA STRANA -->
        <!-- ========================= -->
        <div class="col-md-3">

            <!-- NOVI ZADATAK -->
            <div class="mb-4" style="max-width:420px;">
                <div class="card shadow-sm p-4" id="taskDataContainer">
                    <h5 class="mb-2">@localizer["Enter new task"]</h5>

                    <div class="mb-1">
                        <tms-input type="Text" name="Name" id="taskName" class="form-control"
                                   label="@localizer["Task name"]:"
                                   placeholder="@localizer["Enter task name"]..." />
                    </div>

                    <div class="mb-1">
                        <tms-input type="Date" name="DueDate" id="taskDueDate" class="form-control"
                                   label="@localizer["Task due date"]:"
                                   placeholder="@localizer["Enter task due date"]..." />
                    </div>

                    <button id="saveTask" class="btn btn-success w-100">
                        @localizer["Save"]
                    </button>
                </div>
            </div>

            <!-- TABELA ZADATAKA -->
            <div class="mb-4" style="max-width:420px;">
                <div class="card shadow-sm">
                    <div class="card-header bg-light"
                         data-bs-toggle="collapse"
                         data-bs-target="#taskTableCollapse"
                         style="cursor:pointer;">
                        @localizer["Click for showing/hiding tasks"]
                    </div>

                    <div id="taskTableCollapse" class="collapse">
                        <div class="card-body p-2">
                            <table class="table table-sm table-striped" id="tasksTable">
                                <thead>
                                    <tr>
                                        <th>@localizer["Name"]</th>
                                        <th>@localizer["Due Date"]</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- NOVI PROJECT TASK -->
            <div class="mb-4" style="max-width:420px;">
                <div class="card shadow-sm p-4" id="projectTaskDataContainer">
                    <h5 class="mb-2">@localizer["Enter new project task"]</h5>

                    <div class="mb-1">
                        <tms-select name="ProjectId" id="ProjectId" options="@Model.Projects"
                                    label="@localizer["Project"]:"
                                    empty-option-text="@localizer["Select project"]..." />
                    </div>

                    <div class="mb-1">
                        <tms-input type="Text" name="Name" id="projectTaskName" class="form-control"
                                   label="@localizer["Task name"]:"
                                   placeholder="@localizer["Enter task name"]..." />
                    </div>

                    <div class="mb-1">
                        <tms-input type="Date" name="DueDate" id="projectTaskDueDate" class="form-control"
                                   label="@localizer["Task due date"]:"
                                   placeholder="@localizer["Enter task due date"]..." />
                    </div>

                    <button class="btn btn-success w-100" id="saveProjectTask">
                        @localizer["Save"]
                    </button>
                </div>
            </div>

            <!-- TABELA PROJECT TASK -->
            <div class="mb-4" style="max-width:420px;">
                <div class="card shadow-sm">
                    <div class="card-header bg-light"
                         data-bs-toggle="collapse"
                         data-bs-target="#projectTaskTableCollapse"
                         style="cursor:pointer;">
                        @localizer["Click for showing/hiding project tasks"]
                    </div>

                    <div id="projectTaskTableCollapse" class="collapse">
                        <div class="card-body p-2">
                            <table class="table table-sm table-striped" id="projectTasksTable">
                                <thead>
                                    <tr>
                                        <th>@localizer["Project"]</th>
                                        <th>@localizer["Name"]</th>
                                        <th>@localizer["Due Date"]</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- NOVA REGULAR ACTIVITY -->
            <div class="mb-4" style="max-width:420px;">
                <div class="card shadow-sm p-4" id="regularActivityDataContainer">
                    <h5 class="mb-2">@localizer["Enter new regular activity"]</h5>

                    <div class="mb-1">
                        <tms-input type="Text" name="Name" id="regularActivityName" class="form-control"
                                   label="@localizer["Regular activity name"]:"
                                   placeholder="@localizer["Enter regular activity name"]..." />
                    </div>

                    <button class="btn btn-success w-100" id="saveRegularActivity">
                        @localizer["Save"]
                    </button>
                </div>
            </div>

            <!-- TABELA REGULAR ACTIVITY -->
            <div class="mb-4" style="max-width:420px;">
                <div class="card shadow-sm">
                    <div class="card-header bg-light"
                         data-bs-toggle="collapse"
                         data-bs-target="#projectRegularActivityTableCollapse"
                         style="cursor:pointer;">
                        @localizer["Click for showing/hiding regular activity"]
                    </div>

                    <div id="projectRegularActivityTableCollapse" class="collapse">
                        <div class="card-body p-2">
                            <table class="table table-sm table-striped" id="regularActivitesTable">
                                <thead>
                                    <tr>
                                        <th>@localizer["Name"]</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ========================= -->
        <!-- DESNA STRANA (nova tabela) -->
        <!-- ========================= -->
        <div class="col-md-9">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center">
                    <span>📅 @localizer["Plans for day"] @Model.Today</span>

                    <!-- NOVI SELECT ZA TIP -->
                    <select id="activityMode" class="form-select form-select-sm w-auto">
                        <option value="">@localizer["Select activity type"]</option>
                        <option value="project">@localizer["Project"]</option>
                        <option value="task">@localizer["Task"]</option>
                        <option value="regular">@localizer["Regular activity"]</option>
                    </select>
                </div>

                <div class="card-body p-3">

                    <div class="table-responsive">
                        <table class="table table-hover table-bordered align-middle" id="manualTable">

                            <!-- HEADER ĆE BITI DINAMIČKI -->
                            <thead id="dynamicTableHead" class="table-light">
                                <tr>
                                    <th class="text-center text-muted">
                                        @localizer["Select activity type to generate table"]
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                <!-- dinamički redovi -->
                            </tbody>
                        </table>
                    </div>

                    <button class="btn btn-success btn-sm px-3 mt-2" id="btnAddRow">
                        ➕ @localizer["Add row"]
                    </button>

                </div>
            </div>
        </div>

    </div>
</div>

@section Styles {
    <link rel="stylesheet" type="text/css" href="~/lib/select2/select2.min.css" />
}
@section Scripts {

    <script type="text/javascript" src="~/lib/select2/select2.min.js"></script>

    <script type="text/javascript">

      const activityTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ActivityTypes));
      const projects = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Projects));
      const tasks = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Tasks));


              $("#activityMode").change(function () {

            let mode = $(this).val();
            let thead = $("#dynamicTableHead");
            let tbody = $("#manualTable tbody");

            thead.empty();
            tbody.empty();

            if (!mode) {
                thead.append(`
                    <tr>
                        <th class="text-center text-muted">
                            @localizer["Select activity type to generate table"]
                        </th>
                    </tr>
                `);
                return;
            }

            if (mode === "project") {
                thead.append(`
                    <tr>
                        <th>@localizer["Project"]</th>
                        <th>@localizer["Task"]</th>
                        <th>@localizer["Activity"]</th>
                        <th>@localizer["From"]</th>
                        <th>@localizer["to"]</th>
                        <th>@localizer["Duration"]</th>
                        <th>@localizer["Order number"]</th>
                        <th>@localizer["Status"]</th>
                    </tr>
                `);
            }

            if (mode === "task") {
                thead.append(`
                    <tr>
                        <th>@localizer["Task"]</th>
                        <th>@localizer["Activity"]</th>
                        <th>@localizer["From"]</th>
                        <th>@localizer["to"]</th>
                        <th>@localizer["Duration"]</th>
                        <th>@localizer["Order number"]</th>
                        <th>@localizer["Status"]</th>
                    </tr>
                `);
            }

            if (mode === "regular") {
                thead.append(`
                    <tr>
                        <th>@localizer["Regular activity"]</th>
                        <th>@localizer["From"]</th>
                        <th>@localizer["to"]</th>
                        <th>@localizer["Duration"]</th>
                        <th>@localizer["Order number"]</th>
                        <th>@localizer["Status"]</th>
                    </tr>
                `);
            }

        });

        $("#btnAddRow").click(function () {

            let mode = $("#activityMode").val();
            let tbody = $("#manualTable tbody");

            if (!mode) {
                alert('@localizer["Select activity type first"]');
                return;
            }

            if (mode === "project") {

                tbody.append(`
                    <tr>
                        <td>
                            <select class="form-select form-select-sm">
                                <option value="">@localizer["Select project"]</option>
                                @foreach (var p in Model.Projects)
                                {
                                        <option value="@p.Value">@p.Description</option>
                                }
                            </select>
                        </td>
                        <td>
                            <select class="form-select form-select-sm">
                                <option value="">@localizer["Select task"]</option>
                                @foreach (var t in Model.Tasks)
                                {
                                        <option value="@t.Value">@t.Description</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input class="form-control form-control-sm"
                                   placeholder="@localizer["Activity"]">
                        </td>
                        <td><input type="time" class="form-control form-control-sm from-time"></td>
                        <td><input type="time" class="form-control form-control-sm to-time"></td>
                        <td><input class="form-control form-control-sm duration" readonly></td>
                        <td><input type="number" class="form-control form-control-sm"></td>
                        <td>
                            <select class="form-select form-select-sm">
                                <option>@localizer["Planned"]</option>
                                <option>@localizer["Done"]</option>
                            </select>
                        </td>
                    </tr>
                `);
            }

            if (mode === "task") {

                tbody.append(`
                    <tr>
                        <td>
                            <select class="form-select form-select-sm">
                                <option value="">@localizer["Select task"]</option>
                                @foreach (var r in Model.Tasks)
                                {
                                        <option value="@r.Value">@r.Description</option>
                                }
                            </select>
                        </td>
                        <td>
                            <input class="form-control form-control-sm"
                                   placeholder="@localizer["Activity"]">
                        </td>
                        <td><input type="time" class="form-control form-control-sm from-time"></td>
                        <td><input type="time" class="form-control form-control-sm to-time"></td>
                        <td><input class="form-control form-control-sm duration" readonly></td>
                        <td><input type="number" class="form-control form-control-sm"></td>
                        <td>
                            <select class="form-select form-select-sm">
                                <option>@localizer["Planned"]</option>
                                <option>@localizer["Done"]</option>
                            </select>
                        </td>
                    </tr>
                `);
            }

            if (mode === "regular") {

                tbody.append(`
                    <tr>
                        <td>
                            <select class="form-select form-select-sm">
                              <option value="">@localizer["Select regular activity"]</option>
                                @foreach (var r in Model.RegularActivities)
                                {
                                        <option value="@r.Value">@r.Description</option>
                                }
                            </select>
                        </td>
                        <td><input type="time" class="form-control form-control-sm from-time"></td>
                        <td><input type="time" class="form-control form-control-sm to-time"></td>
                        <td><input class="form-control form-control-sm duration" readonly></td>
                        <td><input type="number" class="form-control form-control-sm"></td>
                        <td>
                            <select class="form-select form-select-sm">
                                <option>@localizer["Planned"]</option>
                                <option>@localizer["Done"]</option>
                            </select>
                        </td>
                    </tr>
                `);
            }

        });

      function addRow() {
            let table = document.getElementById("manualTable").getElementsByTagName('tbody')[0];
            let row = table.insertRow();

            row.innerHTML = `
                <td>
                    <select class="form-select form-select-sm" name="ActivityTypeId">
                        <option value="">-- Select --</option>
                        ${activityTypes.map(x => `<option value="${x.Value}">${x.Description}</option>`).join('')}
                    </select>
                </td>

                <td>
                    <select class="form-select form-sm" name="ProjectId">
                        <option value="">-- Select --</option>
                              ${projects.map(x => `<option value="${x.Value}">${x.Description}</option>`).join('')}
                    </select>
                </td>

                <td>
                    <select class="form-select form-sm" name="TaskId">
                        <option value="">-- Select --</option>
                              ${tasks.map(x => `<option value="${x.Value}">${x.Description}</option>`).join('')}
                    </select>
                </td>

                <td><input type="text" class="form-control form-control-sm" name="activity" /></td>
                <td><input type="time" class="form-control form-control-sm" name="from" /></td>
                <td><input type="time" class="form-control form-control-sm" name="to" /></td>
                <td><input type="text" class="form-control form-control-sm" name="duration" readonly /></td>
                <td><input type="text" class="form-control form-control-sm" name="orderNumber" /></td>
                <td>
                    <select class="form-select form-select-sm" name="status">
                        <option>Open</option>
                        <option>In progress</option>
                        <option>Done</option>
                    </select>
                </td>
            `;
        }

        function searchTasks() {
            $.ajax({
                url: "@Url.RouteUrl(RouteNames.IdaTasks_Search)",
                method: "POST",
                success: function (response) {

                    var rows = "";

                    $.each(response, function (i, task) {

                        var dueDate = "";
                        if (task.dueDate) {
                            var date = new Date(task.dueDate);
                            dueDate = date.toLocaleDateString("sr-RS");
                        }

                        rows += "<tr>";
                        rows += "<td>" + task.name + "</td>";
                        rows += "<td>" + dueDate + "</td>";
                        rows += "</tr>";
                    });

                    $("#tasksTable tbody").html(rows);

                    // PRIKAŽI COLLAPSE TABELU
                    $("#taskTableCollapse").collapse("show");
                },
                error: function () {
                    alert("Greška pri učitavanju zadataka.");
                }
            });
        }

        function searchRegularActivities() {
            $.ajax({
                url: "@Url.RouteUrl(RouteNames.RegularActivities_Search)",
                method: "POST",
                success: function (response) {

                    var rows = "";

                    $.each(response, function (i, task) {

                        rows += "<tr>";
                        rows += "<td>" + task.name + "</td>";
                        rows += "</tr>";
                    });

                    $("#regularActivitesTable tbody").html(rows);

                    $("#projectRegularActivityTableCollapse").collapse("show");
                },
                error: function () {
                    alert("Greška pri učitavanju zadataka.");
                }
            });
        }

        function searchProjectTasks() {
            $.ajax({
                url: "@Url.RouteUrl(RouteNames.IdaTasks_Search)",
                method: "POST",
                data:{ hasProject : true},
                success: function (response) {

                    var rows = "";

                    $.each(response, function (i, task) {

                        var dueDate = "";
                        if (task.dueDate) {
                            var date = new Date(task.dueDate);
                            dueDate = date.toLocaleDateString("sr-RS");
                        }

                        rows += "<tr>";
                        rows += "<td>" + (task.project ? task.project : "") + "</td>";
                        rows += "<td>" + task.name + "</td>";
                        rows += "<td>" + dueDate + "</td>";
                        rows += "</tr>";
                    });

                    $("#projectTasksTable tbody").html(rows);

                    $("#projectTaskTableCollapse").collapse("show");
                },
                error: function () {
                    alert("Greška pri učitavanju projektnih zadataka.");
                }
            });
        }

        $(document).ready(function () {
            searchTasks();
            searchProjectTasks();
            searchRegularActivities();
            $("#saveTask").click(function () {
                var $inputsContainer = $("#taskDataContainer");

                if (validateRequiredFields($inputsContainer, '@localizer["ValidationMsg"]')) {
                    var jsonData = serializeJSON($inputsContainer);

                    $.ajax({
                        url: "@Url.RouteUrl(RouteNames.IdaTasks_Save)",
                        method: "POST",
                        data: jsonData,
                        success: function (response) {
                            handleActionResponseMessage(response, function () {
                                searchTasks();
                            }, '@localizer["Error"]', '@localizer["SavedMsg"]');
                        }
                    });
                }
            });
            $("#saveProjectTask").click(function () {
                var $inputsContainer = $("#projectTaskDataContainer");

                if (validateRequiredFields($inputsContainer, '@localizer["ValidationMsg"]')) {
                    var jsonData = serializeJSON($inputsContainer);

                    $.ajax({
                        url: "@Url.RouteUrl(RouteNames.IdaTasks_Save)",
                        method: "POST",
                        data: jsonData,
                        success: function (response) {
                            handleActionResponseMessage(response, function () {
                                searchProjectTasks();
                            }, '@localizer["Error"]', '@localizer["SavedMsg"]');
                        }
                    });
                }
            });

            $("#saveRegularActivity").click(function () {
                var $inputsContainer = $("#regularActivityDataContainer");

                if (validateRequiredFields($inputsContainer, '@localizer["ValidationMsg"]')) {
                    var jsonData = serializeJSON($inputsContainer);

                    $.ajax({
                        url: "@Url.RouteUrl(RouteNames.RegularActivities_Save)",
                        method: "POST",
                        data: jsonData,
                        success: function (response) {
                            handleActionResponseMessage(response, function () {
                                searchRegularActivities();
                            }, '@localizer["Error"]', '@localizer["SavedMsg"]');
                        }
                    });
                }
            });

            $("#ProjectId").select2({});
        });
    </script>
}