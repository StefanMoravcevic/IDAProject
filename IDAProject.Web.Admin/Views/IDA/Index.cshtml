						row.find("select[name='IdaTaskId'], select[name='ProjectId'], select[name='RegularActivityId']").val("");

						// Popuni dropdownove zavisno od tipa
						if (res.activityTypeId == 1) {
							row.find("select[name='ProjectId']").val(res.projectId);
							row.find("select[name='IdaTaskId']").val(res.taskId);
						}
						else if (res.activityTypeId == 2) {
							row.find("select[name='IdaTaskId']").val(res.taskId);
						}
						else if (res.activityTypeId == 3) {
							let regularSelect = row.find("select[name='RegularActivityId']");
							regularSelect.val(res.regularActivityId); // int, OK
							regularSelect.trigger("change"); // ponekad je potrebno da select "osveži" UI
						}

						// Ostala polja
						row.find("input[name='ActivityName']").val(res.activityName);
						row.find("input[name='TimeFromFormatted']").val(res.timeFrom);
						row.find("input[name='TimeToFormatted']").val(res.timeTo);
						row.find("input[name='DurationFormatted']").val(res.duration);

			
					}
				});
			});

			$(document).on("change", "select[name='ActivityTypeId']", function() {
				let activityTypeId = $(this).val();
				let row = $(this).closest("tr");

				updateColumnsByActivityType(activityTypeId, row);
			});

			$(document).on("click", ".saveRealRow", function () {

					let row = $(this).closest("tr");
					let data = serializeJSON(row);

					let button = $(this);
					button.prop("disabled", true);

					$.ajax({
						url: "@Url.RouteUrl(RouteNames.TasksRealizations_Save)",
						method: "POST",
						data: data,
						success: function (response) {
							searchTaskRealizationPopulateTable();
							handleActionResponseMessage(response, function () {

							},'@localizer["Error"]', '@localizer["SavedMsg"]');
						},
						error: function () {
							alert("Error saving row");
							button.prop("disabled", false);
						}
					});
				});
		});
	</script>
}
